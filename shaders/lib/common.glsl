float minOf(vec3 v) { return min(min(v.x, v.y), v.z); }
float maxOf(vec3 v) { return max(max(v.x, v.y), v.z); }

float fmix(float a, float b, float t) {
    t = min(max(t, 0.0), 1.0);
    return a + t * (b - a);
}

vec3 fmix(vec3 a, vec3 b, vec3 t) {
    t = min(max(t, 0.0), 1.0);
    return a + t * (b - a);
}

vec3 fmix(vec3 a, vec3 b, float t) {
    t = min(max(t, 0.0), 1.0);
    return a + t * (b - a);
}

